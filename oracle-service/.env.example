# Pocket Fans oracle-service config. Copy to .env and adjust. All optional —
# sensible devnet defaults are baked in (see src/config.cjs).

# --- Solana RPC ---
# Set ONE of these. Both the poller's goal-watch loop and any getProgramAccounts
# call need a gPA-capable endpoint; the PUBLIC devnet RPC rate-limits gPA hard,
# which shows up as "no rules found" rather than an error.
#
# LOCALLY these are picked up from the sibling ../../shroudline/.env. That file
# DOES NOT EXIST ON RAILWAY — you must set one of these in the Railway dashboard,
# or the poller will refuse to start with GOAL_WATCH_ENABLED=true.
# RPC_URL=
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=...

# TxLINE API. TXLINE_API_TOKEN is REQUIRED for the poller; if not set here it
# is read from the sibling ../../shroudline/.env (same token Witness uses) —
# no secret copied.
# TXLINE_API_TOKEN=...
# TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# COMPETITION_ID=72

# --- Supabase (fixtures cache) — REQUIRED for `npm run poller` ---
# Project URL and SERVICE ROLE key (not the anon key — this daemon needs
# write access). Find both under Project Settings -> API in the Supabase
# dashboard. Never expose the service role key to a browser context.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...

# Poller intervals (ms). Defaults: forward list every 5 min, live fixtures
# checked every 20s. Lower POLL_LIVE_MS = fresher "finished" status sooner,
# more TxLINE calls (fine on the free SL1 tier — no rate limit).
# POLL_FORWARD_MS=300000
# POLL_LIVE_MS=20000

# Fixtures to treat as knockout stage (comma-separated FixtureIds). Knockout =
# no draw (level after full time is decided by penalties 6001/6002).
# KNOCKOUT_FIXTURE_IDS=

# Extra FixtureIds to probe for a finished result even if they have dropped off
# the forward snapshot (useful for the dry-run demo on a real finished match).
# PROBE_FIXTURE_IDS=

# Program id (deployed on devnet). Defaults to the live program.
# PROGRAM_ID=4f74EBY7KMe8mUP9MpNzRnPzW6LojYX8wm56ZZz3iDgB

# --- GoalScored keeper (execute_rule_verified) ---
# The dedicated keeper identity that signs + pays fees for execute_rule_verified.
# NOT a user wallet: it holds no user funds and has NO privilege in the program
# (the instruction trusts the Txoracle CPI verdict, never the signer). Worst case
# if it leaks: someone wastes its SOL on tx fees. It can never move user funds.
#
# Supply it ONE of two ways. KEEPER_SECRET_KEY wins if both are set.
#
# 1) KEEPER_SECRET_KEY — the secret key as a JSON array STRING. Use this on
#    Railway and any platform without file mounts. Set it in the dashboard's
#    secret store — NEVER commit it or paste it into a repo file.
#      KEEPER_SECRET_KEY=[12,34,56, ... 64 bytes total ...]
#    (that's exactly the contents of the solana-keygen file below, on one line)
#
# 2) KEEPER_KEYPAIR_PATH — a keypair file. For LOCAL DEV.
#    Defaults to ~/.config/solana/pocket-fans-keeper.json
#      solana-keygen new --no-bip39-passphrase -o ~/.config/solana/pocket-fans-keeper.json
#      solana airdrop 2 <PUBKEY> --url devnet
# KEEPER_SECRET_KEY=
# KEEPER_KEYPAIR_PATH=

# Master switch for the goal-watch loop. While false the loop is not even
# scheduled and no signer is ever loaded.
#
# When true, the poller REFUSES TO START unless all of these are present:
#   - RPC_URL or HELIUS_RPC_URL   (gPA-capable — see the Solana RPC section above)
#   - KEEPER_SECRET_KEY or KEEPER_KEYPAIR_PATH
#   - TXLINE_API_TOKEN
#   - SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (already required by the poller)
# It fails loudly on purpose: a half-configured keeper silently never fires.
# GOAL_WATCH_ENABLED=false

# How often to check live fixtures that have an open GoalScored rule.
# POLL_GOAL_WATCH_MS=15000
