# Pocket Fans oracle-service config. Copy to .env and adjust. All optional —
# sensible devnet defaults are baked in (see src/config.cjs).

# Solana devnet RPC. Defaults to public devnet RPC.
# RPC_URL=

# TxLINE API. TXLINE_API_TOKEN is REQUIRED for the poller; if not set here it
# is read from the sibling ../../shroudline/.env (same token Witness uses) —
# no secret copied.
# TXLINE_API_TOKEN=...
# TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# COMPETITION_ID=72

# --- Supabase (fixtures cache) — REQUIRED for `npm run poller` ---
# Project URL and SERVICE ROLE key (not the anon key — this daemon needs
# write access). Find both under Project Settings -> API in the Supabase
# dashboard. Never expose the service role key to a browser context.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...

# Poller intervals (ms). Defaults: forward list every 5 min, live fixtures
# checked every 20s. Lower POLL_LIVE_MS = fresher "finished" status sooner,
# more TxLINE calls (fine on the free SL1 tier — no rate limit).
# POLL_FORWARD_MS=300000
# POLL_LIVE_MS=20000

# Fixtures to treat as knockout stage (comma-separated FixtureIds). Knockout =
# no draw (level after full time is decided by penalties 6001/6002).
# KNOCKOUT_FIXTURE_IDS=

# Extra FixtureIds to probe for a finished result even if they have dropped off
# the forward snapshot (useful for the dry-run demo on a real finished match).
# PROBE_FIXTURE_IDS=

# Program id (deployed on devnet). Defaults to the live program.
# PROGRAM_ID=4f74EBY7KMe8mUP9MpNzRnPzW6LojYX8wm56ZZz3iDgB
